# Copier vers .env a la racine du depot (a cote de backend/ et frontend/)

# Django
SECRET_KEY=django-insecure-change-me-in-dev
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Base de donnees : laisser DB_NAME vide pour SQLite, ou remplir pour PostgreSQL
# DB_NAME=plateforme_stages_db
# DB_USER=postgres
# DB_PASSWORD=
# DB_HOST=localhost
# DB_PORT=5432

# Google Sign-In — Client ID OAuth (Applications Web Google Cloud)
# Fichiers .env racine backend : verifier le jeton Serveur doit avoir la meme ID que Vite pour le JWT.
# GOOGLE_OAUTH_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com

# Google Gemini (lettre motivation, entretien, scraping par lots)
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-1.5-flash

# Scraping : nombre d'offres par requete Gemini (2 a 12 recommande)
# GEMINI_SCRAPER_CHUNK=8

# Limites API DRF (scopes anon / user / gemini_user)
# DRF_THROTTLE_ANON=120/hour
# DRF_THROTTLE_USER=4000/hour
# DRF_THROTTLE_GEMINI=90/hour

# Frontend (Vite)
# VITE_API_URL=http://127.0.0.1:8000/api
# Meme valeur que GOOGLE_OAUTH_CLIENT_ID (identifiant client OAuth Web)
# VITE_GOOGLE_CLIENT_ID=
